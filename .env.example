# Vite (browser) — required for `src/lib/supabase.ts`.
# Copy to `.env` or `.env.local` for local dev. Hosted builds must inject the same values
# for the Supabase project where Edge functions are deployed.
#
# Project alignment: `VITE_SUPABASE_URL` host must be `https://<project-ref>.supabase.co`
# for the same project you deploy with `supabase functions deploy` / Dashboard.
# See docs/GMAIL_ROLLOUT_RUNBOOK.md §0.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_from_project_api_settings

# Operator Ana (dashboard) — must match the Edge function secret to enable end-to-end streaming:
#   Server (Supabase Edge secret): OPERATOR_ASSISTANT_STREAMING_V1=true
#   Client (Vite build): VITE_OPERATOR_ASSISTANT_STREAMING_V1=true
# Both must be "true" for the widget to use direct fetch+SSE; leave unset or "false" for legacy invoke+JSON.
# VITE_OPERATOR_ASSISTANT_STREAMING_V1=

# Optional: `[Ana stream] …` console timing logs in the operator widget (also on in Vite dev without this).
# Edge (optional): set secret `OPERATOR_ASSISTANT_STREAM_DEBUG=true` for one JSON log per stream with tokenSseEventCount.
# VITE_ANA_STREAM_DEBUG=

# Operator Ana LLM provider (Supabase Edge secret for `operator-studio-assistant`, or env for `supabase functions serve`).
# Default: OpenAI — requires OPENAI_API_KEY (existing). Model defaults to gpt-4o-mini unless ANA_LLM_MODEL is set.
# Optional Gemini test: ANA_LLM_PROVIDER=google and GEMINI_API_KEY (Google AI Studio / Gemini API key). Default Gemini model: gemini-2.5-flash.
# Gemini path is JSON text-only: read-only operator_lookup_* tools are not invoked (answers use Context + session; server logs a warning when supabase would have enabled tools).
# ANA_LLM_PROVIDER=openai
# ANA_LLM_MODEL=
# GEMINI_API_KEY=
